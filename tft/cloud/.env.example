PORT=8080
JWT_SECRET=change_me_super_secret

# np. mqtts://broker.hivemq.cloud:8883
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# topic bazowy: <prefix>/<device_id>/...
MQTT_TOPIC_PREFIX=wms
DEVICE_ONLINE_TTL_MS=90000
# krótszy TTL używany tylko w oknie "Dodaj urządzenie", żeby szybciej znikały odłączone urządzenia
COMPATIBLE_DEVICE_ONLINE_TTL_MS=20000
PUBLIC_BASE_URL=https://www.wmsprinkler.pl

# AdSense (puste wyłączy wstrzykiwanie skryptu)
ADSENSE_CLIENT_ID=ca-pub-4043853774720196

# Lista emaili administratorów (oddzielona przecinkami)
ADMIN_EMAILS=

# Wbudowane konto administratora (login/hasło)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=9521mycode

# ACK komend (MQTT)
CMD_ACK_TIMEOUT_MS=4000
REQUIRE_CMD_ACK=true

# Rate limit (API)
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_CLAIM_MAX=20
RATE_LIMIT_CLAIM_WINDOW_MS=600000

# Sesja użytkownika (bezczynność)
SESSION_IDLE_TIMEOUT_MS=600000
# Dla zaznaczonego "Zapamiętaj mnie" (domyślnie 30 dni)
SESSION_IDLE_TIMEOUT_REMEMBER_MS=2592000000
SESSION_REMEMBER_MAX_AGE_MS=2592000000
SESSION_TOKEN_TTL=30d

# Automatyczne usuwanie kont bez przypisanego urządzenia (dni bez logowania)
STALE_UNASSIGNED_USER_RETENTION_DAYS=30
# Co ile ms wykonać housekeeping bazy (migracje + auto-cleanup kont)
DB_HOUSEKEEPING_INTERVAL_MS=21600000

# Opcjonalnie: webhook do alertów (cloud/mqtt down)
ALERT_WEBHOOK_URL=

# Home Assistant / MQTT (izolacja per urządzenie)
HA_MQTT_HOST=wmsprinkler.pl
HA_MQTT_PORT=8883
HA_MQTT_TLS=true
HA_DISCOVERY_PREFIX=homeassistant
HA_MQTT_USER_PREFIX=ha_

# OTA signing (Ed25519) - wymagane dla bezpiecznych kampanii OTA
# Ustaw jedno z pól:
OTA_SIGN_PRIVATE_KEY_PATH=
# OTA_SIGN_PRIVATE_KEY_PEM_B64=

# Tymczasowo: od tej daty (ISO) raportowanie hardware przez urządzenia znów będzie wymagane.
# Przed tą datą kampanie OTA dopuszczają urządzenia z hardware=unknown.
OTA_REQUIRE_HARDWARE_REPORT_FROM=2026-07-01T00:00:00+02:00

# Opcjonalnie: hook uruchamiany po claim/unclaim/rotacji haseł HA
# Przykład:
# MQTT_AUTH_SYNC_HOOK=sudo /var/www/wmsprinkler/cloud/scripts/sync-ha-mqtt-auth.sh
MQTT_AUTH_SYNC_HOOK=

# (opcjonalnie dla skryptu sync-ha-mqtt-auth.js)
# WMS_MQTT_SERVICE_USERS=wms_device
